# Ignored files for remaju-scraper

# Dependencies
node_modules/
package-lock.json

# Build output (monorepo — each app/package manages its own dist/)
dist/
.next/
apps/*/dist/
packages/*/dist/

# Turbo cache
.turbo/
apps/*/.turbo/
packages/*/.turbo/

# TypeScript incremental build info
*.tsbuildinfo

# Environment variables (contains secrets)
.env

# Data and logs
data/
logs/
output/

# Browser profile data (Puppeteer/Playwright userDataDir)
browser-data/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# openspec (if using file-based artifacts)
openspec/

# Test artifacts
coverage/
.nyc_output/

# Ad-hoc debugging scripts
check-db-schema.js
inspect-card.js
query-first-five.js
