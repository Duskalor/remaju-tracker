{
  "name": "@remaju/database",
  "version": "1.0.0",
  "description": "Database layer for Remaju Intelligence System — Drizzle ORM with SQLite (dev) and PostgreSQL (prod)",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "db:backup": "node scripts/backup.cjs",
    "db:push": "node scripts/backup.cjs && drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@remaju/shared": "workspace:*",
    "better-sqlite3": "12.9.0",
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.13",
    "drizzle-kit": "0.31.10",
    "rimraf": "6.0.0",
    "typescript": "6.0.3"
  }
}
