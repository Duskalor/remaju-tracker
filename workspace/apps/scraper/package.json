{
  "name": "@remaju/scraper",
  "version": "1.0.0",
  "description": "REMAJU (Registro de bienes en remate judicial) scraper with TypeScript - Extracts auction data from remaju.pj.gob.pe",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "scraper",
    "remaju",
    "judicial",
    "auction",
    "typescript",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@remaju/database": "workspace:*",
    "@remaju/regex-engine": "workspace:*",
    "@remaju/shared": "workspace:*",
    "cheerio": "^1.2.0",
    "dotenv": "^17.0.0",
    "playwright": "npm:rebrowser-playwright@^1.52.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.0"
  }
}
