{
  "name": "@remaju/scraper",
  "version": "1.0.0",
  "description": "REMAJU (Registro de bienes en remate judicial) scraper with TypeScript - Extracts auction data from remaju.pj.gob.pe",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/main.js",
    "dev": "ts-node src/main.ts",
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "scraper",
    "remaju",
    "judicial",
    "auction",
    "typescript",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@remaju/database": "workspace:*",
    "@remaju/regex-engine": "workspace:*",
    "@remaju/shared": "workspace:*",
    "cheerio": "1.2.0",
    "dotenv": "17.4.2",
    "playwright": "npm:rebrowser-playwright@1.59.1",
    "winston": "3.19.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.2",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  }
}
