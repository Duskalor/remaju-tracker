{
  "name": "remaju-scraper",
  "version": "1.0.0",
  "description": "REMAJU (Registro de bienes en remate judicial) scraper with TypeScript - Extracts auction data from rema ju.pj.gob.pe",
  "main": "dist/scraper.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/scraper.js",
    "dev": "ts-node src/scraper.ts",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "keywords": [
    "scraper",
    "remaju",
    "judicial",
    "auction",
    "typescript",
    "playwright"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@types/sql.js": "^1.4.11",
    "cheerio": "^1.2.0",
    "dotenv": "^16.3.1",
    "playwright": "^1.40.0",
    "sql.js": "^1.14.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/cheerio": "^0.22.35",
    "@types/node": "^20.10.0",
    "rimraf": "^5.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
